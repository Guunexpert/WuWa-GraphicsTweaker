<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- WuWa Color Palette -->
    <Color x:Key="WuWaBackgroundColor">#0D1117</Color>
    <Color x:Key="WuWaSurfaceColor">#161B22</Color>
    <Color x:Key="WuWaSurface2Color">#1C2128</Color>
    <Color x:Key="WuWaGoldColor">#E8C170</Color>
    <Color x:Key="WuWaCyanColor">#4FC3F7</Color>
    <Color x:Key="WuWaTextColor">#E6EDF3</Color>
    <Color x:Key="WuWaTextMutedColor">#8B949E</Color>
    <Color x:Key="WuWaDangerColor">#F85149</Color>
    <Color x:Key="WuWaSuccessColor">#3FB950</Color>
    <Color x:Key="WuWaBorderColor">#30363D</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WuWaBackgroundBrush" Color="{StaticResource WuWaBackgroundColor}" />
    <SolidColorBrush x:Key="WuWaSurfaceBrush" Color="{StaticResource WuWaSurfaceColor}" />
    <SolidColorBrush x:Key="WuWaSurface2Brush" Color="{StaticResource WuWaSurface2Color}" />
    <SolidColorBrush x:Key="WuWaGoldBrush" Color="{StaticResource WuWaGoldColor}" />
    <SolidColorBrush x:Key="WuWaCyanBrush" Color="{StaticResource WuWaCyanColor}" />
    <SolidColorBrush x:Key="WuWaTextBrush" Color="{StaticResource WuWaTextColor}" />
    <SolidColorBrush x:Key="WuWaTextMutedBrush" Color="{StaticResource WuWaTextMutedColor}" />
    <SolidColorBrush x:Key="WuWaDangerBrush" Color="{StaticResource WuWaDangerColor}" />
    <SolidColorBrush x:Key="WuWaSuccessBrush" Color="{StaticResource WuWaSuccessColor}" />
    <SolidColorBrush x:Key="WuWaBorderBrush" Color="{StaticResource WuWaBorderColor}" />

    <!-- Gold Gradient -->
    <LinearGradientBrush x:Key="WuWaGoldGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E8C170" Offset="0" />
        <GradientStop Color="#F5D78E" Offset="0.5" />
        <GradientStop Color="#C9A84C" Offset="1" />
    </LinearGradientBrush>

    <!-- Sidebar item style -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource WuWaTextMutedBrush}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1C2128" />
                            <Setter Property="Foreground" Value="{StaticResource WuWaTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#21262D" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
        <Setter Property="Background" Value="#1C2128" />
        <Setter Property="Foreground" Value="{StaticResource WuWaGoldBrush}" />
    </Style>

    <!-- Card style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WuWaSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WuWaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

</ResourceDictionary>
