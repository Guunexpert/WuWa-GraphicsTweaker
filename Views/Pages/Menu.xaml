<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:PhoebeEditor.Views.Pages"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="PhoebeEditor.Views.Pages.Menu"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Menu">


    <Grid>

        <MediaElement
              x:Name="VideoBg"
              Source="pack://siteoforigin:,,,/Views/Pages/hiyuki-wuthering-waves.1920x1080.mov" 
              LoadedBehavior="Play" 
              UnloadedBehavior="Manual"
              IsMuted="True" 
              Stretch="UniformToFill"
              RenderOptions.BitmapScalingMode="LowQuality"
              MediaEnded="VideoBg_MediaEnded" Opacity="0.6" />
        <Image Source="pack://application:,,,/Views/Pages/wuwa.png" 
           Width="250"
           Margin="0,0,540,357"
           RenderOptions.BitmapScalingMode="LowQuality" Height="90" />

       


    </Grid>
</Page>