<Window x:Class="PhoebeEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:PhoebeEditor.ViewModels"
        xmlns:pages="clr-namespace:PhoebeEditor.Views.Pages"
        Title="Phoebe Editor"
        Width="1120" Height="620"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WuWaBackgroundBrush}"
        WindowStyle="None" FontFamily="Cascadia Mono SemiBold" Icon="/Views/phoebe.png">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="12"
            Background="{StaticResource WuWaBackgroundBrush}"
            BorderBrush="{StaticResource WuWaBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Border Grid.Column="0"
                    Background="{StaticResource WuWaSurfaceBrush}"
                    BorderBrush="{StaticResource WuWaBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo / Title -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,20"
                                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <TextBlock Text="Phoebe Editor"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WuWaGoldBrush}" />
                        <TextBlock Text="LAUNCHER"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource WuWaTextMutedBrush}"
                                    />
                        <!-- Gold accent line -->
                        <Rectangle Height="1"
                                   Margin="0,12,0,0"
                                   Fill="{StaticResource WuWaGoldGradientBrush}"
                                   Opacity="0.5" />
                    </StackPanel>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1" Margin="12,8">
                        <Border x:Name="BtnMenu"
                            Background="#1C2128" CornerRadius="6" Padding="16,12"
                            Cursor="Hand" MouseLeftButtonDown="NavItem_Click" Tag="menu" Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🏠" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource WuWaGoldBrush}" />
                                            <TextBlock Text="Main Menu" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"
                                       Foreground="{StaticResource WuWaGoldBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="BtnLauncher"
                            Background="Transparent" CornerRadius="6" Padding="16,12"
                            Cursor="Hand" MouseLeftButtonDown="NavItem_Click" Tag="launcher" Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="▶" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource WuWaTextMutedBrush}" />
                                <TextBlock Text="Launcher" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"
                                       Foreground="{StaticResource WuWaTextMutedBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="BtnTweaks"
                            Background="Transparent" CornerRadius="6" Padding="16,12"
                            Cursor="Hand" MouseLeftButtonDown="NavItem_Click" Tag="tweaks" Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource WuWaTextMutedBrush}" />
                                        <TextBlock Text="Graphics Tweaks" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"
                                       Foreground="{StaticResource WuWaTextMutedBrush}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="BtnPresets"
                            Background="Transparent" CornerRadius="6" Padding="16,12"
                            Cursor="Hand" MouseLeftButtonDown="NavItem_Click" Tag="presets" Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="◈" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource WuWaTextMutedBrush}" />
                                                <TextBlock Text="Presets" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"
                                       Foreground="{StaticResource WuWaTextMutedBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Game Status -->
                    <Border Grid.Row="2"
                            Margin="12,0,12,16"
                            Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="GAME STATUS"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource WuWaTextMutedBrush}"                                      
                                       Margin="0,0,0,6" />
                            <TextBlock x:Name="TxtStatus"
                                       Text="{Binding StatusMessage}"
                                       Foreground="{Binding StatusColor}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Titlebar drag area + close button -->
                <Grid Grid.Row="0"
                      Background="Transparent"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <Button Content="—" Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="MinimizeButton_Click"
                                FontSize="14" 
                                Foreground="White"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                        <Button Content="✕" Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CloseButton_Click"
                                FontSize="12" 
                                Foreground="White"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Pages (Frame) -->
                <Frame x:Name="MainFrame"
                       Grid.Row="1"
                       NavigationUIVisibility="Hidden" Background="{x:Null}" />
            </Grid>
        </Grid>
    </Border>
</Window>
