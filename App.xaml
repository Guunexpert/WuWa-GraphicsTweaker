<Application x:Class="PhoebeEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:PhoebeEditor.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Resources/WuWaTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:LauncherToSteamBgConverter x:Key="LauncherToSteamBg" />
            <converters:LauncherToSteamBorderConverter x:Key="LauncherToSteamBorder" />
            <converters:LauncherToSteamTextConverter x:Key="LauncherToSteamText" />
            <converters:LauncherToKuroBgConverter x:Key="LauncherToKuroBg" />
            <converters:LauncherToKuroBorderConverter x:Key="LauncherToKuroBorder" />
            <converters:LauncherToKuroTextConverter x:Key="LauncherToKuroText" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
